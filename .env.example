# Bazaar reads the shared Arc root .env (../.env) automatically.
# These are the variables it uses. Copy to .env and fill — TESTNET ONLY.

# Arc Testnet network
ARC_TESTNET_RPC=https://rpc.testnet.arc.network
ARC_TESTNET_CHAIN_ID=5042002
ARC_TESTNET_EXPLORER=https://testnet.arcscan.app

# Reused, already-deployed Cadence nanopayment rail (native USDC, 18 decimals)
ESCROW_V2_ADDRESS=0xc95b1b20f91901206ba3ea94bbc7313e7cd82f8d

# Slice-1 wallets (testnet only). PRIVATE_KEY = buyer/MAIN funder, SERVICE_PRIVATE_KEY = seller.
PRIVATE_KEY=0x...
SERVICE_PRIVATE_KEY=0x...

# Per-agent seller wallets (testnet only) — required by demo / economy / trustless / beginner / byoa:ext / market.
BAZAAR_SELLER_A_ADDR=0x...
BAZAAR_SELLER_A_PK=0x...
BAZAAR_SELLER_B_ADDR=0x...
BAZAAR_SELLER_B_PK=0x...
BAZAAR_SELLER_C_ADDR=0x...
BAZAAR_SELLER_C_PK=0x...

# Trustless-slash validators are auto-generated + funded + staked on first `npm run trustless`
# (written back here as BAZAAR_VALIDATOR_{1,2,3}_{PK,ADDR}). Knobs:
# BAZAAR_VALIDATOR_MODELS=deepseek-v4-pro,deepseek-v4-flash,deepseek-chat   # distinct model per validator
# BAZAAR_OUTLIER=3:9000                # force validator 3 off-consensus to demo on-chain validator slashing

# Circle Developer-Controlled Wallets (for circle:pay / circle:trustless). Get CIRCLE_API_KEY from
# console.circle.com (Sandbox -> Keys -> API Keys; format TEST_API_KEY:<id>:<secret>), then run
# `npm run circle:setup` (does the entity-secret ceremony + creates the wallets + writes circle-wallets.json).
# CIRCLE_API_KEY=TEST_API_KEY:...
# CIRCLE_ENTITY_SECRET=...             # written by circle:setup; the master key — keep secret, never commit
# CIRCLE_WALLET_SET_ID=...             # written by circle:setup

# Agent brain — set ONE to enable REAL LLM reasoning (else agents use a labeled heuristic).
# Provider-agnostic: priority DeepSeek -> OpenAI-compatible -> Anthropic.
# Recommended (cheap, good for a 10-day continuous run):
# DEEPSEEK_API_KEY=sk-...
# BAZAAR_MODEL=deepseek-chat          # or deepseek-reasoner for richer rationale
#
# Any OpenAI-compatible endpoint also works:
# OPENAI_API_KEY=...
# OPENAI_BASE_URL=https://api.openai.com/v1
# BAZAAR_MODEL=gpt-4o-mini
#
# Or Anthropic:
# ANTHROPIC_API_KEY=sk-ant-...
# BAZAAR_MODEL=claude-haiku-4-5-20251001
